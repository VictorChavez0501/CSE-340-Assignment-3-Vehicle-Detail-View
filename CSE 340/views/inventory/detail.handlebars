<section class="vehicle-detail-container">

  <div class="vehicle-detail-grid">

    <!-- IMAGEN -->
    <div class="vehicle-detail-image">
      <img src="{{vehicle.inv_image}}" alt="{{vehicle.inv_make}} {{vehicle.inv_model}}">
    </div>

    <!-- INFO -->
    <div class="vehicle-detail-info">
      <h1 class="vehicle-title">
        {{vehicle.inv_year}} {{vehicle.inv_make}} {{vehicle.inv_model}}
      </h1>

      <p class="vehicle-price">{{formattedPrice}}</p>

      <ul class="vehicle-specs">
        <li><strong>Mileage:</strong> {{formattedMiles}} miles</li>
        <li><strong>Color:</strong> {{vehicle.inv_color}}</li>
        <li><strong>Fuel:</strong> Gasoline</li>
        <li><strong>Transmission:</strong> Automatic</li>
        <li><strong>Drive:</strong> FWD</li>
      </ul>

      <div class="vehicle-description">
        <h3>Description</h3>
        <p>{{vehicle.inv_description}}</p>
      </div>

      <div class="vehicle-actions">
        <button class="btn-primary">START MY PURCHASE</button>
        <button class="btn-secondary">CONTACT US</button>
        <button class="btn-secondary">SCHEDULE TEST DRIVE</button>
      </div>

    </div>

  </div>

</section>